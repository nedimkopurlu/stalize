# PostgreSQL — Railway otomatik sağlar, aşağıdaki formatı kullan
# asyncpg (uygulama içi bağlantı)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# psycopg2 (alembic migration)
DATABASE_SYNC_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Debug — üretimde False yap
DEBUG=False
